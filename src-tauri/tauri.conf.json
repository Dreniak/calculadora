{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calculadora de Pensão Alimentícia",
  "version": "1.0.0",
  "identifier": "br.jus.tjto.calculadora-pensao",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Calculadora Judicial de Pensão Alimentícia",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "pt-BR"
      },
      "nsis": {
        "languages": ["PortugueseBR"],
        "installMode": "perMachine"
      }
    }
  }
}
